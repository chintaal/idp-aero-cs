# ── Server ────────────────────────────────────────────────────────────────────
ARTIFACTS_DIR=artifacts
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000

# ── Training ──────────────────────────────────────────────────────────────────
DEVICE=cpu          # set to "cuda" if a GPU is available
EPOCHS=150
BATCH_SIZE=512
LEARNING_RATE=3e-4

# ── Simulation ────────────────────────────────────────────────────────────────
N_FLIGHTS=3000
SAMPLES_PER_FLIGHT=20
RANDOM_SEED=42
